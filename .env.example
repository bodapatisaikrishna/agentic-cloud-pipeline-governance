# ACDE configuration — copy to .env (git-ignored) and adjust.
# Every value here maps 1:1 to a field in src/acde/config.py (Settings).

# --- Postgres ---
POSTGRES_HOST=localhost
# Host-published port. Default 5433 (not 5432) so the stack coexists with a
# locally-installed PostgreSQL already using 5432. The container is 5432 internally.
POSTGRES_PORT=5433
POSTGRES_USER=acde
POSTGRES_PASSWORD=acde
POSTGRES_DB=acde
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=8
DB_RETRY_ATTEMPTS=3
DB_RETRY_BACKOFF_S=0.5

# --- Streaming broker (Redpanda) ---
# Host clients use localhost:9092; services inside the compose network use redpanda:29092.
BROKER_BOOTSTRAP=localhost:9092
STREAM_TOPIC=acde.stream.events
STREAM_DEFAULT_WORKERS=2
STREAM_MIN_WORKERS=1
STREAM_MAX_WORKERS=8
STREAM_WINDOW_S=60

# --- Datasets ---
DATA_DIR=data
TPCDS_SCALE_ROWS=20000
OPENGOV_ROWS=5000
# Opt-in to real public data (needs network + disk); default is seeded synthetic.
USE_REAL_TLC=0
USE_REAL_OPENGOV=0

# --- Policy engine (OPA) ---
OPA_URL=http://localhost:8181
OPA_PORT=8181

# --- Airflow REST API (Phase 1+) ---
AIRFLOW_URL=http://localhost:8080/api/v1
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin

# --- LLM layer ---
# Required only for live runs (MOCK_LLM=0). Never commit a real key.
# Live-call provider: anthropic (default) or gemini.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
MODEL_REASONING=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5
# Gemini (only when LLM_PROVIDER=gemini). Override the model IDs here if they change.
GEMINI_API_KEY=
GEMINI_MODEL_REASONING=gemini-2.5-pro
GEMINI_MODEL_FAST=gemini-2.5-flash
# 1 = deterministic mock responses, zero API calls (default everywhere incl. CI)
MOCK_LLM=1
LLM_MAX_CALLS_PER_RUN=60
LLM_MAX_TOKENS_PER_RUN=150000
LLM_MAX_TOKENS_PER_CALL=1024

# --- Cost model (§5.5, disclosed) ---
COST_RATE_COMPUTE_UNIT_SECOND=0.05
COST_RATE_STORAGE_GB_HOUR=0.01

# --- SLAs ---
FRESHNESS_SLA_STREAMING_S=60

# --- Policy plane ---
BUDGET_DEFAULT_UNITS=100
RATE_LIMIT_MAX_PER_10MIN=5

# --- Human simulator (§6 baseline) ---
HUMAN_LATENCY_MEDIAN_S=360
HUMAN_LATENCY_SIGMA=0.5

# --- Agents / anomaly detection (Phase 5) ---
ANOMALY_Z_THRESHOLD=3.0
CPU_HIGH_PCT=80
AGENT_MIN_CONFIDENCE=0.0

# --- Orchestrator (Phase 6) ---
MONITORING_INTERVAL_S=15
SOAK_DURATION_S=1200

# --- Chaos harness (Phase 4) ---
CHAOS_WARMUP_S=120
CHAOS_FAULT_WINDOW_S=180
CHAOS_RECOVERY_S=120
CHAOS_HARD_CAP_S=720
# resource_contention: 0 = host multiprocessing CPU stress (default), 1 = stress-ng container
STRESS_USE_CONTAINER=0
STRESS_IMAGE=ghcr.io/colinianking/stress-ng:latest

# --- Telemetry ---
EXPERIMENT_RUN=adhoc
TELEMETRY_INTERVAL_S=5
COST_WINDOW_S=60

# --- Determinism ---
DEFAULT_SEED=42

# --- Logging ---
LOG_LEVEL=INFO
