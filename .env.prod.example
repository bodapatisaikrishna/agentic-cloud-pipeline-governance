# ACDE production configuration — copy to .env.prod and fill in. NEVER commit real secrets.
# Only the knobs a production deployment needs. See docs/OPERATIONS.md for the full guide.

# --- Safety: start in SHADOW (log proposals, never touch the pipeline). Graduate to approval,
#     then autonomous, only after you trust the proposals for your pipelines.
ACDE_MODE=shadow
# Action types that ALWAYS require human approval, even in autonomous mode (comma-separated).
APPROVAL_REQUIRED_ACTION_TYPES=rollback,quarantine_partition,block_ingestion
# Hard cap on executed actions per target per hour (0 = unlimited). Set a sane bound in prod.
BLAST_RADIUS_MAX_PER_HOUR=5

# --- Operator API (required). Generate a strong random key; the API refuses to start without it.
API_KEY=
API_HOST=0.0.0.0
API_PORT=8099

# --- Database (bring your own managed Postgres in real deployments)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=acde
POSTGRES_PASSWORD=
POSTGRES_DB=acde

# --- Policy engine
OPA_URL=http://opa:8181

# --- Connector: attach ACDE to YOUR orchestrator ("airflow" or "noop" for observe-only)
CONNECTOR_KIND=airflow
AIRFLOW_URL=https://airflow.your-company.com/api/v1
AIRFLOW_USER=
AIRFLOW_PASSWORD=
# Or use a bearer token instead of basic auth:
# AIRFLOW_AUTH_TOKEN=
AIRFLOW_VERIFY_TLS=true

# --- LLM provider (set MOCK_LLM=0 for real reasoning; pick a provider + its key)
MOCK_LLM=1
LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# For on-prem / data-residency, use an OpenAI-compatible endpoint (e.g. self-hosted / NVIDIA NIM):
# LLM_PROVIDER=openai_compatible
# OAI_BASE_URL=https://your-inference-host/v1
# OAI_API_KEY=

# --- Notifications (Slack-compatible webhook; leave empty to disable)
WEBHOOK_URL=
WEBHOOK_EVENTS=pending_approval,escalation,execution_failure
